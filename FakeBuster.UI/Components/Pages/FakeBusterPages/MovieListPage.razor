@inject NavigationManager NavManager
@inject IMovieRepository MovieRepository
@inject IContentItemRepository ContentItemRepository

@page "/Movies"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="d-flex flex-row justify-content-between">
  <h3>Movies</h3>
  <button class="btn btn-primary" @onclick="@(() => DetailsBtn("New"))">New</button>
</div>

<table class="table">
  <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">Copies</th>
      <th scope="col">@nameof(Movie.Title)</th>
      <th scope="col">@nameof(Movie.Description)</th>
      <th scope="col">@nameof(Movie.ReleaseDate)</th>
      <th scope="col">@nameof(Movie.DurationMinutes)</th>
      <th scope="col">@nameof(ContentItem.Language)</th>
      <th scope="col">@nameof(Movie.Genres)</th>
      <th scope="col"></th>
    </tr>
  </thead>
  <tbody>
    @foreach (var movie in MovieList)
    {
      <tr>
        <th scope="row">@movie.Id</th>
        <td>@movie.ContentItems.Count</td>
        <td>@movie.Title</td>
        <td>@movie.Description</td>
        <td>@movie.ReleaseDate</td>
        <td>@movie.DurationMinutes</td>
        <td>@string.Join(", ", movie.ContentItems!.Select(x => x.Language).Distinct() ?? [])</td>
        <td>@string.Join(", ", movie.Genres.Select(g => g.Name) ?? [])</td>
        <td>
          <button class="btn btn-link" @onclick="@(() => DetailsBtn(movie.Id.ToString()))">Edit</button> |
          <button class="btn btn-link" @onclick="@(() => AddCopyBtn(movie.Id.ToString()))">Add Copy</button> |
          <button class="btn btn-link" @onclick="@(() => DeleteBtn(movie.Id))">Delete</button>
        </td>
      </tr>
    }
  </tbody>
</table>

@code {
  public List<Movie> MovieList { get; set; } = [];

  protected override async Task OnInitializedAsync()
  {
    MovieList = await GetAllMovies();
  }

  public async Task<List<Movie>> GetAllMovies()
  {
    return await MovieRepository.GetAll();
  }

  public void DetailsBtn(string id)
  {
    NavManager.NavigateTo($"Movies/{id}");
  }

  public void AddCopyBtn(string id)
  {
    NavManager.NavigateTo($"Movies/{id}/AddCopy");
  }

  public async Task DeleteBtn(int id)
  {
    await MovieRepository.Delete(id);
    MovieList = await GetAllMovies();
  }
}

